# ── Gemini Flash (RECOMMENDED for enrichment) ────────────────────────
# Free: 15 RPM, 1M tokens/day, 1500 requests/day
# Enriches all 1700 models in ~2 hours in one sitting
# Get free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# ── Groq (free: ~100 models/day for enrichment) ──────────────────────
# Get free key: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# ── Cerebras (free: 60,000 TPM — used for chat agents) ───────────────
# Get free key: https://cloud.cerebras.ai
CEREBRAS_API_KEY=csk_your_key_here

# ── LLM Provider ─────────────────────────────────────────────────────
# For enrichment (run_update.py / enrich_only.py):
#   "gemini"   → Gemini Flash (BEST: 1M tokens/day free, done in 2 hours)
#   "groq"     → Groq Llama 3.3 70B (~100 models/day, hits daily limit)
#   "ollama"   → local Ollama (unlimited but slow on CPU)
#
# For chat agents (app.py): always uses Groq → Cerebras fallback
LLM_PROVIDER=gemini

OLLAMA_MODEL=qwen3:4b
