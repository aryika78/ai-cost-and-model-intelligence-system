# ── Groq (free: 6,000 TPM) ──────────────────────────────────────────
# Get free key: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# ── Cerebras (free: 60,000 TPM — 10x Groq, same model) ──────────────
# Get free key: https://cloud.cerebras.ai
# Set this to auto-fallback when Groq rate-limits
CEREBRAS_API_KEY=csk_your_key_here

# ── LLM Provider ─────────────────────────────────────────────────────
# "groq"     → use Groq (auto-falls back to Cerebras if rate-limited)
# "cerebras" → use Cerebras directly (higher limits, recommended)
# "ollama"   → local Ollama (slow on CPU, no internet needed)
LLM_PROVIDER=groq

# For enrichment (run_update.py): must be "groq" or "ollama"
# Cerebras not used for bulk enrichment (use Groq for that)

OLLAMA_MODEL=qwen3:4b
